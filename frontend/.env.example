# Optional: full API origin (no trailing slash). Leave EMPTY in local dev so requests go to the same
# origin as Vite (e.g. http://192.168.x.x:8080/api/...) and the proxy forwards to the backend — avoids CORS.
# Only set VITE_API_URL for production builds or when the API must be called cross-origin on purpose.
VITE_API_URL=

# Dev proxy target — must match backend HOST:PORT (see backend .env). If backend binds a LAN IP only, use e.g. http://192.168.88.21:6001
VITE_PROXY_TARGET=http://127.0.0.1:6001

# Optional Vite dev server port
# VITE_PORT=8080
